# Copy this file to .env and fill in keys you actually have.
# Never commit real secrets.

IPINFO_TOKEN=
IPQUALITYSCORE_API_KEY=
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Optional: comma-separated chat IDs allowed to use the bot.
TELEGRAM_ALLOWED_CHAT_IDS=
# Optional: comma-separated admin chat IDs for /admin panel.
TELEGRAM_ADMIN_CHAT_IDS=
# Optional: comma-separated admin user IDs for /admin panel (recommended).
TELEGRAM_ADMIN_USER_IDS=
# Optional: Mini App URL for Telegram keyboard button.
TELEGRAM_MINI_APP_URL=
# Legacy alias for Mini App URL.
MINI_APP_URL=
# Optional: PDF report publishing settings (public URL to generated reports).
REPORTS_PUBLIC_DIR=
REPORTS_BASE_URL=
REPORTS_FONT_PATH=

# Green orders group (Telegram)
GREEN_ORDER_CHAT_ID=
# Optional: topic/thread ID for forum groups
GREEN_ORDER_THREAD_ID=

# Telegram user account (for "Мои чаты: номер")
# Get API_ID/API_HASH at https://my.telegram.org
TG_USER_API_ID=
TG_USER_API_HASH=
# String session value or path to session file (at least one of them).
TG_USER_SESSION=
TG_USER_SESSION_FILE=
# Target chat/channel for auto-send when number is not found.
TG_USER_TARGET_CHAT=
# Optional tuning
TG_USER_DIALOGS_LIMIT=150
TG_USER_FOUND_LIMIT=8
TG_USER_SEND_TEMPLATE=Номер {phone} не найден в моих чатах.

# Virtual numbers provider (Mini App "Номер для мессенджеров")
# Provider API key (sms-activate compatible API)
SMS_ACTIVATE_API_KEY=
# API endpoint (default: sms-activate compatible)
SMS_ACTIVATE_BASE_URL=https://api.sms-activate.org/stubs/handler_api.php
# Service codes by messenger
SMS_ACTIVATE_SERVICE_TELEGRAM=tg
SMS_ACTIVATE_SERVICE_MAX=ot
SMS_ACTIVATE_SERVICE_WHATSAPP=wa
# Country / operator filters for provider API
SMS_ACTIVATE_COUNTRY=0
SMS_ACTIVATE_OPERATOR=
# Cooldown between "Запросить ещё" actions (seconds)
SMS_ACTIVATE_MIN_RETRY_SECONDS=60
# HTTP timeout to provider API (seconds)
SMS_ACTIVATE_TIMEOUT_SECONDS=20

# Google Sheets (report 767 export)
# Either set GOOGLE_SHEETS_CREDENTIALS_JSON to a service account JSON file path,
# or set GOOGLE_SHEETS_CREDENTIALS to the JSON content.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB=report767
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_CREDENTIALS=

# Second Telegram bot instance (telegram_bot_copy.py)
TELEGRAM_BOT_TOKEN_COPY=
# Optional: comma-separated chat IDs allowed to use the second bot.
TELEGRAM_ALLOWED_CHAT_IDS_COPY=

# Official FSSP API token for /fssp command in telegram_bot.py
FSSP_API_TOKEN=
# Optional override for second bot instance.
FSSP_API_TOKEN_COPY=

DIRECTORY_DB_PATH=business_directory.db
